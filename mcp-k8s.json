                "QUARKUS_REST_CLIENT_CRYOSTAT_VERIFY_HOST": "false",
                "QUARKUS_REST_CLIENT_CRYOSTAT_TLS_CONFIGURATION_NAME": "notls",
                "CRYOSTAT_AUTH_VALUE": "Bearer sha256~SEU5dRLwgseRAH28f2FakoedFbScjVzE6oiyP3LCq7M",
                "QUARKUS_SMALLRYE_GRAPHQL_CLIENT_CRYOSTAT_TLS_CONFIGURATION_NAME": "notls",
                "QUARKUS_SMALLRYE_GRAPHQL_CLIENT_CRYOSTAT_URL": "https://cryostat-sample-cryostat.apps-crc.testing/api/v4/graphql"
            }
        }
    }
