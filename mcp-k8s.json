{
    "mcpServers": {
        "cryostat-k8s": {
            "command": "jbang",
            "args": [
                "--quiet",
                "io.cryostat:cryostat-mcp:0.1.0-SNAPSHOT:runner"
            ],
            "env": {
                "CRYOSTAT_AUTH_VALUE": "Bearer $my_token",
                "QUARKUS_REST_CLIENT_CRYOSTAT_URL": "https://cryostat-instance.cryostat-namespace.mycluster/",
                "QUARKUS_SMALLRYE_GRAPHQL_CLIENT_CRYOSTAT_URL": "https://cryostat-instance.cryostat-namespace.mycluster/api/v4/graphql"
            }
        }
    }
}
