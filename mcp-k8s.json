{
    "mcpServers": {
        "cryostat-k8s": {
            "command": "jbang",
            "args": [
                "--quiet",
                "io.cryostat:cryostat-mcp:1.0.0-SNAPSHOT:runner"
            ],
            "env": {
                "QUARKUS_TLS_NOTLS_TRUST_ALL": "true",
                "QUARKUS_TLS_NOTLS_HOSTNAME_VERIFICATION_ALGORITHM": "NONE",
